<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineScope</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <!-- ⭐ Dark Mode Toggle -->
    <button id="darkToggle" class="btn btn-sm btn-dark position-fixed"
            style="top: 20px; right: 20px; z-index: 999;">
        Dark Mode
    </button>

    <!-- ⭐ NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                CINE SCOPE
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#cineNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="cineNavbar">

                <!-- Left Menu -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Movies" asp-action="Index">Movies</a>
                    </li>
                </ul>

                <!-- Search -->
                <form class="d-flex me-3" method="get" asp-controller="Movies" asp-action="Index">
                    <input class="form-control me-2" type="search" name="search" placeholder="Search movies...">
                    <button class="btn btn-outline-light" type="submit">Search</button>
                </form>

                <!-- Login / Register / Logout -->
                <partial name="_LoginPartial" />

            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT -->
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CineScope
        </div>
    </footer>

    <!-- ⭐ Dark Mode Script -->
    <style>
            .dark-mode {
                background-color: #121212 !important;
                color: white !important;
            }

                .dark-mode .navbar,
                .dark-mode footer {
                    background-color: #1e1e1e !important;
                    color: white !important;
                }

                .dark-mode .nav-link {
                    color: #ddd !important;
                }

                .dark-mode .card,
                .dark-mode .movie-card {
                    background-color: #1e1e1e !important;
                    color: white !important;
                }
    </style>

    <script>
            const toggle = document.getElementById("darkToggle");
            toggle.addEventListener("click", () => {
                document.body.classList.toggle("dark-mode");
            });
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
