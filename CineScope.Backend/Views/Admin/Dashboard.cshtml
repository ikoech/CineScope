@using CineScope.Backend.Models.ViewModels
@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mb-4">Admin Dashboard</h2>

<div class="row g-4">

    <div class="col-md-4">
        <div class="card shadow text-center p-3">
            <h4>Total Movies</h4>
            <h2>@Model.TotalMovies</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow text-center p-3">
            <h4>Total Users</h4>
            <h2>@Model.TotalUsers</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow text-center p-3">
            <h4>Total Reviews</h4>
            <h2>@Model.TotalReviews</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow text-center p-3">
            <h4>Total Ratings</h4>
            <h2>@Model.TotalRatings</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow text-center p-3">
            <h4>Total Favorites</h4>
            <h2>@Model.TotalFavorites</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow text-center p-3">
            <h4>New Users Today</h4>
            <h2>@Model.NewUsersToday</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow text-center p-3">
            <h4>New Reviews Today</h4>
            <h2>@Model.NewReviewsToday</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow text-center p-3">
            <h4>Movies Added This Month</h4>
            <h2>@Model.MoviesThisMonth</h2>
        </div>
    </div>

</div>
