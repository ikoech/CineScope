@model UserWithRolesViewModel

@{
    ViewData["Title"] = "Delete User";
}

<h1>Delete User</h1>

<p>Are you sure you want to delete this user?</p>

<div class="mb-3">
    <strong>Email:</strong> @Model.Email
</div>

<div class="mb-3">
    <strong>Username:</strong> @Model.UserName
</div>

<div class="mb-3">
    <strong>Roles:</strong> @string.Join(", ", Model.Roles)
</div>

<form asp-action="DeleteUserConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="ManageUsers" class="btn btn-secondary">Cancel</a>
</form>
