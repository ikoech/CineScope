@model CineScope.Backend.Controllers.HomeViewModel

@{
    ViewData["Title"] = "CineScope – Movies";
}

<div class="container mt-4">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-light">Movies</h2>

        <!-- Genre Filter -->
        <form method="get" class="d-flex">
            <select name="genre" class="form-select me-2" onchange="this.form.submit()">
                <option value="">All Genres</option>

                @foreach (var g in Model.Genres)
                {
                    <option value="@g" selected="@(g == Model.SelectedGenre)">
                        @g
                    </option>
                }
            </select>

            <button type="submit" class="btn btn-primary">Filter</button>
        </form>
    </div>

    <!-- Movie Grid -->
    <div class="row g-4">
        @foreach (var movie in Model.Movies)
        {
            <div class="col-md-3 col-sm-6">
                <div class="card bg-dark text-white shadow-sm movie-card h-100">

                    <!-- Poster -->
                    <img src="@movie.PosterUrl" class="card-img-top" alt="@movie.Title" />

                    <div class="card-body">
                        <h5 class="card-title">@movie.Title</h5>
                        <p class="card-text text-secondary">@movie.Genre</p>
                    </div>

                    <div class="card-footer border-0 bg-transparent">
                        <a href="/Movies/Details/@movie.Id" class="btn btn-outline-light w-100">
                            View Details
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>

</div>

<!-- Optional hover animation -->
<style>
    .movie-card {
        transition: transform .2s ease, box-shadow .2s ease;
    }

        .movie-card:hover {
            transform: scale(1.03);
            box-shadow: 0 0 20px rgba(255,255,255,0.2);
        }
</style>
