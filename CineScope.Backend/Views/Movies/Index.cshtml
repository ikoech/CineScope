@model IEnumerable<CineScope.Backend.Models.Movie>

@{
    ViewData["Title"] = "Movies";
}

<h1 class="mb-4">Movies</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex" style="max-width: 350px;">
        <input type="text" name="search" class="form-control" placeholder="Search by title..." />
        <button class="btn btn-primary ms-2">Search</button>
    </form>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-success">+ Add Movie</a>
    }
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Poster</th>
            <th>Title</th>
            <th>Genre</th>
            <th>Year</th>
            <th>Rating</th>
            <th>Duration</th>
            <th style="width: 200px;"></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var movie in Model)
        {
            <tr>
                <td>
                    <img src="@movie.PosterUrl" alt="@movie.Title poster"
                         style="width: 60px; height: 90px; object-fit: cover; border-radius: 4px;" />
                </td>

                <td>@movie.Title</td>
                <td>@movie.Genre?.Name</td>
                <td>@movie.ReleaseYear</td>
                <td>@movie.Rating</td>
                <td>@movie.Duration min</td>

                <td>
                    <a class="btn btn-info btn-sm"
                       asp-action="Details"
                       asp-route-id="@movie.Id">
                        Details
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a class="btn btn-warning btn-sm"
                           asp-action="Edit"
                           asp-route-id="@movie.Id">
                            Edit
                        </a>

                        <a class="btn btn-danger btn-sm"
                           asp-action="Delete"
                           asp-route-id="@movie.Id">
                            Delete
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
