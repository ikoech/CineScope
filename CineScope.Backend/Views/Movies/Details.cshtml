@model CineScope.Backend.Models.Movie

@{
    ViewData["Title"] = "Movie Details";
}

<h2>Movie Details</h2>

<div class="row mt-4">
    <div class="col-md-4">
        <img src="@Model.PosterUrl" alt="@Model.Title poster"
             class="img-fluid rounded" />
    </div>

    <div class="col-md-8">
        <h3>@Model.Title</h3>

        <p><strong>Genre:</strong> @Model.Genre</p>
        <p><strong>Release Year:</strong> @Model.ReleaseYear</p>
        <p><strong>Rating:</strong> @Model.Rating</p>
        <p><strong>Duration:</strong> @Model.Duration min</p>

        <p class="mt-3">@Model.Description</p>

        @if (User.Identity.IsAuthenticated && User.IsInRole("Member"))
        {
            <form asp-controller="Favorites" asp-action="Add" method="post" class="mt-3">
                <input type="hidden" name="movieId" value="@Model.Id" />
                <button class="btn btn-warning">
                    ⭐ Add to Favorites
                </button>
            </form>
        }

        @if (User.Identity.IsAuthenticated && User.IsInRole("Member"))
        {
            <h4 class="mt-4">Rate This Movie</h4>

            <form asp-controller="Ratings" asp-action="Rate" method="post">
                <input type="hidden" name="movieId" value="@Model.Id" />

                <select name="score" class="form-select" style="max-width: 150px;">
                    @for (int i = 1; i <= 10; i++)
                    {
                        <option value="@i">@i / 10</option>
                    }
                </select>

                <button class="btn btn-primary mt-2">Submit Rating</button>
            </form>
        }

        @if (Model.Ratings != null && Model.Ratings.Any())
        {
            var avg = Model.Ratings.Average(r => r.Score);
            <p class="mt-3"><strong>Average Rating:</strong> @avg.ToString("0.0") / 10</p>
        }
        else
        {
            <p class="text-muted mt-3">No ratings yet.</p>
        }
        @if (User.Identity.IsAuthenticated && User.IsInRole("Member"))
        {
            var myRating = Model.Ratings.FirstOrDefault(r => r.User?.UserName == User.Identity.Name);

            if (myRating != null)
            {
                <p class="text-info">Your Rating: @myRating.Score / 10</p>
            }
        }



        <a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>
    </div>
</div>

<hr class="mt-5" />

<h3>Reviews</h3>

@if (Model.Reviews != null && Model.Reviews.Any())
{
    @foreach (var review in Model.Reviews)
    {
        <div class="card my-3">
            <div class="card-body">
                <p>@review.Content</p>
                <small class="text-muted">
                    Posted by @review.User?.UserName on @review.CreatedAt.ToShortDateString()
                </small>

                @if (User.Identity.IsAuthenticated
                    && User.IsInRole("Member")
                    && review.User?.UserName == User.Identity.Name)
                {
                    <form asp-controller="Reviews" asp-action="Delete" method="post" class="mt-2">
                        <input type="hidden" name="id" value="@review.Id" />
                        <button class="btn btn-danger btn-sm">Delete</button>
                    </form>
                }
            </div>
        </div>
    }
}
else
{
    <p class="text-muted">No reviews yet. Be the first to write one!</p>
}

@if (User.Identity.IsAuthenticated && User.IsInRole("Member"))
{
    <h4 class="mt-4">Write a Review</h4>

    <form asp-controller="Reviews" asp-action="Add" method="post">
        <input type="hidden" name="movieId" value="@Model.Id" />

        <textarea name="content" class="form-control" rows="3" placeholder="Write your review..."></textarea>

        <button class="btn btn-primary mt-2">Submit Review</button>
    </form>
}
else
{
    <p class="text-muted mt-3">Login as a Member to write a review.</p>
}