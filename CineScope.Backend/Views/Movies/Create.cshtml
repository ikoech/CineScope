@model CineScope.Backend.Models.Movie

@{
    ViewData["Title"] = "Create";
}

<h1>Create Movie</h1>

<h4>Movie</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- TITLE -->
            <div class="form-group mb-3">
                <label asp-for="Title" class="control-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <!-- GENRE DROPDOWN (FIXED) -->
            <div class="form-group mb-3">
                <label asp-for="GenreId" class="control-label"></label>
                <select asp-for="GenreId"
                        class="form-control"
                        asp-items="ViewBag.GenreId">
                    <option value="">-- Select Genre --</option>
                </select>
                <span asp-validation-for="GenreId" class="text-danger"></span>
            </div>

            <!-- RELEASE YEAR -->
            <div class="form-group mb-3">
                <label asp-for="ReleaseYear" class="control-label"></label>
                <input asp-for="ReleaseYear" class="form-control" />
                <span asp-validation-for="ReleaseYear" class="text-danger"></span>
            </div>

            <!-- RATING -->
            <div class="form-group mb-3">
                <label asp-for="Rating" class="control-label"></label>
                <input asp-for="Rating" class="form-control" />
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>

            <!-- DURATION -->
            <div class="form-group mb-3">
                <label asp-for="Duration" class="control-label"></label>
                <input asp-for="Duration" class="form-control" />
                <span asp-validation-for="Duration" class="text-danger"></span>
            </div>

            <!-- POSTER URL -->
            <div class="form-group mb-3">
                <label asp-for="PosterUrl" class="control-label"></label>
                <input asp-for="PosterUrl"
                       class="form-control"
                       placeholder="Leave empty to auto‑fetch from TMDB" />
                <span asp-validation-for="PosterUrl" class="text-danger"></span>
            </div>

            <!-- DESCRIPTION -->
            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- SUBMIT -->
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

