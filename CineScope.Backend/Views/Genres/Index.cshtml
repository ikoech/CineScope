@model IEnumerable<Genre>

<h2 class="mb-4">Genres</h2>

<div class="row">
    @foreach (var genre in Model)
    {
        <div class="col-md-3 mb-3">
            <a asp-action="Details" asp-route-id="@genre.Id" class="btn btn-outline-primary w-100">
                @genre.Name
            </a>
        </div>
    }
</div>

@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-success mt-3">Add Genre</a>
}
